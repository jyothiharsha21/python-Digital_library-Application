pipeline {
    agent any
    environment {
        DOCKER_REPO = "jyothiharsha05/digitallibrary"
    }
    stages {
        stage('Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/jyothiharsha21/python-Digital_library-Application.git'
            }
        }
        stage('Build Docker Images') {
            steps {
                sh 'docker-compose build'
            }
        }
        stage('Start Containers') {
            steps {
                sh 'docker-compose up -d'
            }
        }
        stage('Tag Images') {
            steps {
                sh '''
                docker tag python_application_deployment_appservice ${DOCKER_REPO}:appservice
                docker tag python_application_deployment_auth ${DOCKER_REPO}:authservice
                docker tag python_application_deployment_books ${DOCKER_REPO}:booksservice
                docker tag python_application_deployment_borrow ${DOCKER_REPO}:borrowservice
                docker tag python_application_deployment_db ${DOCKER_REPO}:dbservice
                '''
            }
        }
        stage('Push Images') {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'dockerhub') {
                        sh '''
                        docker push ${DOCKER_REPO}:appservice
                        docker push ${DOCKER_REPO}:authservice
                        docker push ${DOCKER_REPO}:booksservice
                        docker push ${DOCKER_REPO}:borrowservice
                        docker push ${DOCKER_REPO}:dbservice
                        '''
                    }
                }
            }
        }
    }
    post {
        success {
            echo "Pipeline completed successfully."
        }
        failure {
            echo "Pipeline failed."
        }
        always {
            sh 'docker-compose down || true'
            sh 'docker image prune -f || true'
        }
    }
}
